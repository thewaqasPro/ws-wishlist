<div
  id="ws-wishlist-config"
  hidden
  data-ws-wishlist-config
  data-proxy-path="{{ block.settings.proxy_path | escape }}"
  data-page-type="{{ request.page_type | escape }}"
  data-product-handle="{% if product %}{{ product.handle | escape }}{% endif %}"
  data-variant-id="{% if product %}{{ product.selected_or_first_available_variant.id }}{% endif %}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
></div>

{% render 'ws-wishlist-assets' %}

{% schema %}
{
  "name": "Wishlist",
  "target": "body",
  "stylesheet": "ws-wishlist.css",
  "settings": [
    {
      "type": "text",
      "id": "proxy_path",
      "label": "App proxy path",
      "default": "/apps/page",
      "info": "Change only if the app proxy URL was customized."
    }
  ]
}
{% endschema %}
