<section
  class="ws-wishlist-page-block container"
  data-ws-wishlist-page
  data-proxy-path="{{ block.settings.proxy_path | escape }}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
>
  <header class="ws-wishlist-page-header">
    <h1>{{ block.settings.heading | escape }}</h1>
    {% if block.settings.description != blank %}
      <p class="ws-wishlist-page-description">{{ block.settings.description | escape }}</p>
    {% endif %}
    <div class="ws-wishlist-page-toolbar" data-ws-wishlist-toolbar></div>
  </header>
  <div data-ws-wishlist-page-content>
    <div class="ws-wishlist-page-loading">
      <span class="ws-wishlist-spinner-large"></span>
      <p>Loading your wishlist…</p>
    </div>
  </div>
</section>

{% render 'ws-wishlist-assets' %}

{% schema %}
{
  "name": "Wishlist page",
  "target": "section",
  "stylesheet": "ws-wishlist.css",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Save your favorite products for later",
      "info": "Shown below the page heading. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "proxy_path",
      "label": "App proxy path",
      "default": "/apps/page",
      "info": "Change only if the app proxy URL was customized."
    }
  ]
}
{% endschema %}
