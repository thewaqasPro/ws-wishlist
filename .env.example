# Shopify app credentials
SHOPIFY_API_KEY=replace_me
SHOPIFY_API_SECRET=replace_me
SHOPIFY_API_SCOPES=read_products,write_app_proxy
SHOPIFY_API_OPTIONAL_SCOPES=
SHOPIFY_APP_URL=https://wishlist.example.com
SHOPIFY_API_VERSION=2026-07

# PostgreSQL
DATABASE_URL=postgresql://wswishlist:change-me@postgres:5432/wswishlist?schema=public

# Use a long, random, stable value. Changing it invalidates stored sessions.
ENCRYPTION_STRING=replace-with-at-least-32-random-characters

# App identity
APP_NAME=WS Wishlist
APP_HANDLE=ws-wishlist

# Storefront app proxy (must match shopify.app.toml)
APP_PROXY_PREFIX=apps
APP_PROXY_SUBPATH=page

# Public plans configured in Shopify Partner Dashboard / App Pricing
SHOPIFY_FREE_PLAN_HANDLE=free-forever
SHOPIFY_GROWTH_PLAN_HANDLE=growth
FREE_ACTIVE_WISHLIST_LIMIT=1000
GROWTH_PLAN_PRICE_USD=9.99
# Leave false until the paid plan and entitlement checks are verified in a test store.
ENFORCE_PLAN_LIMITS=false

# Optional: canonical Shopify App Pricing subscription lookup through Partner API
SHOPIFY_PARTNER_ORGANIZATION_ID=
SHOPIFY_PARTNER_ACCESS_TOKEN=
SHOPIFY_PARTNER_APP_ID=
SHOPIFY_PARTNER_API_VERSION=2026-07

# Optional app behavior
POS_EMBEDDED=false
DIRECT_API_MODE=online
EMBEDDED_APP_DIRECT_API_ACCESS=false
NEXT_TELEMETRY_DISABLED=1
PORT=3000

# Docker Compose PostgreSQL container
POSTGRES_DB=wswishlist
POSTGRES_USER=wswishlist
POSTGRES_PASSWORD=change-me
